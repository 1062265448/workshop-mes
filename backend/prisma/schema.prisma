// Workshop MES Database Schema
// Generator: Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户模块 ====================
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  email     String   @unique
  name      String
  role      String   @default("user") // admin, manager, user
  avatar    String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  meetingParticipants MeetingParticipant[]
  projectMembers      ProjectMember[]
  projects            Project[]          @relation("ProjectManager")
  organizedMeetings   Meeting[]          @relation("MeetingOrganizer")
}

// ==================== 会议模块 ====================
model Meeting {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  type        String   @default("general") // general, weekly, review, emergency
  startTime   DateTime
  endTime     DateTime
  location    String?
  organizerId Int
  status      String   @default("scheduled") // scheduled, ongoing, completed, cancelled
  notes       String?  @db.Text // 会议纪要
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer   User                 @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  participants MeetingParticipant[]
  tasks       MeetingTask[]
  attachments MeetingAttachment[]
}

model MeetingParticipant {
  id        Int      @id @default(autoincrement())
  meetingId Int
  userId    Int
  status    String   @default("pending") // pending, confirmed, absent
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
}

model MeetingTask {
  id          Int      @id @default(autoincrement())
  meetingId   Int
  title       String
  description String?  @db.Text
  assigneeId  Int?
  dueDate     DateTime?
  status      String   @default("pending") // pending, in_progress, done, cancelled
  priority    String   @default("medium") // low, medium, high, urgent
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model MeetingAttachment {
  id        Int      @id @default(autoincrement())
  meetingId Int
  name      String
  url       String
  size      Int?     // 文件大小 (字节)
  type      String?  // 文件类型
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

// ==================== 安全管理 ====================
model SafetyTraining {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  trainer     String
  startTime   DateTime
  endTime     DateTime
  location    String?
  attendees   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SafetyInspection {
  id          Int      @id @default(autoincrement())
  title       String
  inspector   String
  date        DateTime
  findings    String?  @db.Text
  status      String   @default("pending") // pending, completed, rectifying
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SafetyIncident {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  date        DateTime
  level       String   // minor, moderate, severe
  status      String   @default("investigating")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== 生产管理 ====================
model ProductionPlan {
  id          Int      @id @default(autoincrement())
  planNo      String   @unique
  product     String
  quantity    Int
  startDate   DateTime
  endDate     DateTime
  status      String   @default("pending") // pending, in_progress, completed, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records ProductionRecord[]
}

model ProductionRecord {
  id        Int      @id @default(autoincrement())
  planId    Int
  date      DateTime
  quantity  Int
  quality   Int
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan ProductionPlan @relation(fields: [planId], references: [id])
}

model NickelInventory {
  id          Int      @id @default(autoincrement())
  tankNo      String   @unique
  batchNo     String?  // 批号
  grade       String?  // 品级 Ni9996/Ni9990/Ni9980/Ni9950
  specification String? // 规格 99.96%
  concentration Decimal @db.Decimal(10, 2) // 浓度 (保留兼容)
  temperature Decimal @db.Decimal(5, 2) // 温度 (保留兼容)
  ph          Decimal @db.Decimal(4, 2) // PH 值 (保留兼容)
  weight      Decimal? @db.Decimal(10, 2) // 重量 (kg)
  pieceCount  Int?     // 片数
  inspectionDate DateTime? // 检测日期
  status      String   @default("available") // available/reserved/used
  location    String?  // 储位
  lastUpdate  DateTime @default(now())
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== 项目管理 ====================
model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime?
  status      String   @default("active") // active, completed, archived
  managerId   Int?
  budget      Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manager   User?            @relation("ProjectManager", fields: [managerId], references: [id])
  members   ProjectMember[]
  documents ProjectDocument[]
}

model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId Int
  userId    Int
  role      String   @default("member") // manager, member, observer
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model ProjectDocument {
  id          Int      @id @default(autoincrement())
  projectId   Int
  name        String
  path        String
  type        String   // file, link
  uploadedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ==================== 缺陷检测 ====================
model DefectType {
  id          Int      @id @default(autoincrement())
  code        String   @unique          // 缺陷代码 (如：HOLE-001)
  name        String                     // 缺陷名称 (如：缺角)
  description String?  @db.Text         // 描述
  category    String?                    // 分类 (如：形状缺陷、表面缺陷)
  color       String?  @default("#ff0000") // 标注框默认颜色
  thumbnailUrl String?                   // 缩略图路径
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  samples     DefectSample[]
  annotations DefectAnnotation[]
}

model DefectSample {
  id          Int      @id @default(autoincrement())
  defectTypeId Int                       // 关联缺陷类型
  imageUrl    String                     // 原图路径
  thumbnailUrl String?                   // 缩略图路径
  sourcePath  String?  @db.Text         // 样本库原始路径
  description String?  @db.Text         // 描述
  status      String   @default("pending") // pending, reviewed, rejected
  reviewedBy  Int?                       // 审核人 ID
  reviewedAt  DateTime?                  // 审核时间
  width       Int?                       // 图片宽度
  height      Int?                       // 图片高度
  fileSize    Int?                       // 文件大小 (字节)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  defectType  DefectType @relation(fields: [defectTypeId], references: [id])
  annotations DefectAnnotation[]
}

// 缺陷标注 (标注框信息)
model DefectAnnotation {
  id           Int      @id @default(autoincrement())
  sampleId     Int                       // 关联样本
  defectTypeId Int                       // 关联缺陷类型
  x            Decimal  @db.Decimal(8, 4) // 标注框 X 坐标 (0-1 之间的小数)
  y            Decimal  @db.Decimal(8, 4) // 标注框 Y 坐标 (0-1 之间的小数)
  width        Decimal  @db.Decimal(8, 4) // 标注框宽度 (0-1 之间的小数)
  height       Decimal  @db.Decimal(8, 4) // 标注框高度 (0-1 之间的小数)
  confidence   Decimal? @db.Decimal(5, 4) // 置信度 (0-1)
  description  String?  @db.Text         // 标注说明
  annotatedBy  Int?                       // 标注人 ID
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sample     DefectSample @relation(fields: [sampleId], references: [id])
  defectType DefectType   @relation(fields: [defectTypeId], references: [id])
}

// ==================== AI 识别历史 ====================
model AiRecognitionHistory {
  id          Int      @id @default(autoincrement())
  imageUrl    String   // 图片路径
  result      String   @db.Text // JSON 格式的识别结果
  itemCount   Int      // 识别到的条目数
  status      String   @default("success") // success, failed
  errorMessage String? @db.Text
  createdAt   DateTime @default(now())
}

// ==================== 平面库配货 ====================
model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  contact     String?
  phone       String?
  address     String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders DistributionOrder[]
}

model DistributionOrder {
  id          Int      @id @default(autoincrement())
  orderNo     String   @unique
  customerId  Int
  items       String   @db.Text // JSON string
  status      String   @default("pending") // pending, processing, completed, cancelled
  shippedAt   DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
}

// ==================== 审计日志 ====================
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  module    String
  details   String?  @db.Text
  ip        String?
  createdAt DateTime @default(now())
}
