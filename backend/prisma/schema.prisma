// Workshop MES Database Schema
// Generator: Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户模块 ====================
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  email     String   @unique
  name      String
  role      String   @default("user") // admin, manager, user
  avatar    String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 关联
  meetingParticipants MeetingParticipant[]
  projectMembers      ProjectMember[]
  projects            Project[]          @relation("ProjectManager")
  organizedMeetings   Meeting[]          @relation("MeetingOrganizer")
}

// ==================== 会议模块 ====================
model Meeting {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  organizerId Int
  status      String   @default("scheduled") // scheduled, ongoing, completed, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer   User                 @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  participants MeetingParticipant[]
}

model MeetingParticipant {
  id        Int      @id @default(autoincrement())
  meetingId Int
  userId    Int
  status    String   @default("pending") // pending, confirmed, absent
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
}

// ==================== 安全管理 ====================
model SafetyTraining {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  trainer     String
  startTime   DateTime
  endTime     DateTime
  location    String?
  attendees   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SafetyInspection {
  id          Int      @id @default(autoincrement())
  title       String
  inspector   String
  date        DateTime
  findings    String?  @db.Text
  status      String   @default("pending") // pending, completed, rectifying
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SafetyIncident {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  date        DateTime
  level       String   // minor, moderate, severe
  status      String   @default("investigating")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== 生产管理 ====================
model ProductionPlan {
  id          Int      @id @default(autoincrement())
  planNo      String   @unique
  product     String
  quantity    Int
  startDate   DateTime
  endDate     DateTime
  status      String   @default("pending") // pending, in_progress, completed, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records ProductionRecord[]
}

model ProductionRecord {
  id        Int      @id @default(autoincrement())
  planId    Int
  date      DateTime
  quantity  Int
  quality   Int
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan ProductionPlan @relation(fields: [planId], references: [id])
}

model NickelInventory {
  id          Int      @id @default(autoincrement())
  tankNo      String   @unique
  concentration Decimal @db.Decimal(10, 2)
  temperature Decimal @db.Decimal(5, 2)
  ph          Decimal @db.Decimal(4, 2)
  lastUpdate  DateTime @default(now())
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== 项目管理 ====================
model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime?
  status      String   @default("active") // active, completed, archived
  managerId   Int?
  budget      Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manager   User?            @relation("ProjectManager", fields: [managerId], references: [id])
  members   ProjectMember[]
  documents ProjectDocument[]
}

model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId Int
  userId    Int
  role      String   @default("member") // manager, member, observer
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model ProjectDocument {
  id          Int      @id @default(autoincrement())
  projectId   Int
  name        String
  path        String
  type        String   // file, link
  uploadedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ==================== 缺陷检测 ====================
model DefectType {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?  @db.Text
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  samples DefectSample[]
}

model DefectSample {
  id          Int      @id @default(autoincrement())
  defectTypeId Int
  imageUrl    String
  description String?  @db.Text
  status      String   @default("pending") // pending, reviewed, rejected
  reviewedBy  Int?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  defectType DefectType @relation(fields: [defectTypeId], references: [id])
}

// ==================== 平面库配货 ====================
model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  contact     String?
  phone       String?
  address     String?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders DistributionOrder[]
}

model DistributionOrder {
  id          Int      @id @default(autoincrement())
  orderNo     String   @unique
  customerId  Int
  items       String   @db.Text // JSON string
  status      String   @default("pending") // pending, processing, completed, cancelled
  shippedAt   DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
}

// ==================== 审计日志 ====================
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  module    String
  details   String?  @db.Text
  ip        String?
  createdAt DateTime @default(now())
}
