// Workshop MES Database Schema
// Generator: Prisma ORM
// Version: v1.4.0 - 生产管理模块重新设计

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户模块 ====================
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  email     String   @unique
  name      String
  role      String   @default("user")
  avatar    String?
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meetingParticipants MeetingParticipant[]
  projectMembers      ProjectMember[]
  projects            Project[]          @relation("ProjectManager")
  organizedMeetings   Meeting[]          @relation("MeetingOrganizer")
}

// ==================== 会议模块 ====================
model Meeting {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  type        String   @default("general")
  startTime   DateTime
  endTime     DateTime
  location    String?
  organizerId Int
  status      String   @default("scheduled")
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizer   User                 @relation("MeetingOrganizer", fields: [organizerId], references: [id])
  participants MeetingParticipant[]
  tasks        MeetingTask[]
  attachments  MeetingAttachment[]
}

model MeetingParticipant {
  id        Int      @id @default(autoincrement())
  meetingId Int
  userId    Int
  status    String   @default("pending")
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
}

model MeetingTask {
  id          Int      @id @default(autoincrement())
  meetingId   Int
  title       String
  description String?  @db.Text
  assigneeId  Int?
  dueDate     DateTime?
  status      String   @default("pending")
  priority    String   @default("medium")
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model MeetingAttachment {
  id        Int      @id @default(autoincrement())
  meetingId Int
  name      String
  url       String
  size      Int?
  type      String?
  createdAt DateTime @default(now())

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

// ==================== 安全管理 ====================
model SafetyTraining {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  trainer     String
  trainTime   DateTime
  duration    Int?
  location    String?
  attendees   String?  @db.Text
  createdAt   DateTime @default(now())
}

model SafetyInspection {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  inspector   String
  inspectTime DateTime
  location    String
  issues      String?  @db.Text
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

model SafetyIncident {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  occurTime   DateTime
  location    String
  level       String
  handler     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
}

// ==================== 项目管理 ====================
model Project {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  managerId   Int
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("planning")
  budget      Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manager User       @relation("ProjectManager", fields: [managerId], references: [id])
  members ProjectMember[]
  tasks   ProjectTask[]
}

model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId Int
  userId    Int
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model ProjectTask {
  id          Int      @id @default(autoincrement())
  projectId   Int
  title       String
  description String?  @db.Text
  assigneeId  Int?
  dueDate     DateTime?
  status      String   @default("pending")
  priority    String   @default("medium")
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ==================== 生产管理模块 ====================

// 车间表
model Workshop {
  id           Int      @id @default(autoincrement())
  workshopCode String   @map("workshop_code") @db.VarChar(20)
  workshopName String   @map("workshop_name") @db.VarChar(100)
  workshopType String?  @map("workshop_type") @db.VarChar(20)
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Int      @default(1) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  inboundRecords  InboundRecord[]
  shippingRecords ShippingRecord[]
  inventories     Inventory[]
  specialStats    SpecialNickelStat[]
  
  @@map("workshop")
}

// 产品规格表
model ProductSpec {
  id                 Int      @id @default(autoincrement())
  productCode        String   @map("product_code") @db.VarChar(20)
  productName        String   @map("product_name") @db.VarChar(100)
  specType           String?  @map("spec_type") @db.VarChar(50)
  specDetail         String?  @map("spec_detail") @db.VarChar(50)
  category           String?  @default("普通") @map("category") @db.VarChar(50)
  subCategory        String?  @map("sub_category") @db.VarChar(50)
  needExportDomestic Int      @default(0) @map("need_export_domestic")
  needSizeBreakdown  Int      @default(0) @map("need_size_breakdown")
  unit               String?  @default("吨") @map("unit") @db.VarChar(20)
  sortOrder          Int      @default(0) @map("sort_order")
  isActive           Int      @default(1) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  
  inboundRecords  InboundRecord[]
  shippingRecords ShippingRecord[]
  inventories     Inventory[]
  
  @@map("product_spec")
  @@index([productCode])
  @@index([category])
}

// 入库记录表
model InboundRecord {
  id                    Int      @id @default(autoincrement())
  recordDate            DateTime @map("record_date") @db.Date
  workshopId            Int      @map("workshop_id")
  productSpecId         Int      @map("product_spec_id")
  totalPackageCount     Int      @default(0) @map("total_package_count")
  totalWeight           Decimal  @default(0) @map("total_weight") @db.Decimal(10, 3)
  exportPackageCount    Int      @default(0) @map("export_package_count")
  exportWeight          Decimal  @default(0) @map("export_weight") @db.Decimal(10, 3)
  domesticPackageCount  Int      @default(0) @map("domestic_package_count")
  domesticWeight        Decimal  @default(0) @map("domestic_weight") @db.Decimal(10, 3)
  remark                String?  @map("remark") @db.Text
  createdBy             String?  @map("created_by")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  
  workshop    Workshop    @relation(fields: [workshopId], references: [id])
  productSpec ProductSpec @relation(fields: [productSpecId], references: [id])
  
  @@map("inbound_record")
  @@index([recordDate])
  @@index([workshopId])
  @@index([productSpecId])
}

// 发运记录表
model ShippingRecord {
  id                 Int      @id @default(autoincrement())
  shipDate           DateTime @map("ship_date") @db.Date
  workshopId         Int      @map("workshop_id")
  productSpecId      Int      @map("product_spec_id")
  totalPackageCount  Int      @default(0) @map("total_package_count")
  totalWeight        Decimal  @default(0) @map("total_weight") @db.Decimal(10, 3)
  exportPackageCount Int      @default(0) @map("export_package_count")
  exportWeight       Decimal  @default(0) @map("export_weight") @db.Decimal(10, 3)
  domesticPackageCount Int    @default(0) @map("domestic_package_count")
  domesticWeight     Decimal  @default(0) @map("domestic_weight") @db.Decimal(10, 3)
  trainSectionCount  Int      @default(0) @map("train_section_count")
  containerCount     Int      @default(0) @map("container_count")
  truckCount         Int      @default(0) @map("truck_count")
  remark             String?  @map("remark") @db.Text
  createdBy          String?  @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  
  workshop    Workshop    @relation(fields: [workshopId], references: [id])
  productSpec ProductSpec @relation(fields: [productSpecId], references: [id])
  
  @@map("shipping_record")
  @@index([shipDate])
}

// 库存表
model Inventory {
  id                   Int      @id @default(autoincrement())
  inventoryDate        DateTime @map("inventory_date") @db.Date
  workshopId           Int      @map("workshop_id")
  productSpecId        Int      @map("product_spec_id")
  totalPackageCount    Int      @default(0) @map("total_package_count")
  totalWeight          Decimal  @default(0) @map("total_weight") @db.Decimal(10, 3)
  exportPackageCount   Int      @default(0) @map("export_package_count")
  exportWeight         Decimal  @default(0) @map("export_weight") @db.Decimal(10, 3)
  domesticPackageCount Int      @default(0) @map("domestic_package_count")
  domesticWeight       Decimal  @default(0) @map("domestic_weight") @db.Decimal(10, 3)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  
  workshop    Workshop    @relation(fields: [workshopId], references: [id])
  productSpec ProductSpec @relation(fields: [productSpecId], references: [id])
  
  @@map("inventory")
  @@unique([inventoryDate, workshopId, productSpecId])
}

// 专用镍统计表
model SpecialNickelStat {
  id               Int      @id @default(autoincrement())
  statDate         DateTime @map("stat_date") @db.Date
  productType      String   @map("product_type") @db.VarChar(100)
  workshopId       Int?     @map("workshop_id")
  inboundPackage   Int      @default(0) @map("inbound_package")
  inboundWeight    Decimal  @default(0) @map("inbound_weight") @db.Decimal(10, 3)
  inboundRemark    String?  @map("inbound_remark") @db.VarChar(200)
  shippingPackage  Int      @default(0) @map("shipping_package")
  shippingWeight   Decimal  @default(0) @map("shipping_weight") @db.Decimal(10, 3)
  inventoryPackage Int      @default(0) @map("inventory_package")
  inventoryWeight  Decimal  @default(0) @map("inventory_weight") @db.Decimal(10, 3)
  remark           String?  @map("remark") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  
  workshop Workshop? @relation(fields: [workshopId], references: [id])
  
  @@map("special_nickel_stat")
  @@index([statDate])
  @@index([productType])
}

// 裁剪率统计表
model CuttingRateStat {
  id              Int      @id @default(autoincrement())
  statDate        DateTime @map("stat_date") @db.Date
  nickelPlateType String?  @map("nickel_plate_type") @db.VarChar(50)
  cutSpec         String?  @map("cut_spec") @db.VarChar(50)
  pieceCount      Int      @default(0) @map("piece_count")
  cuttingRate     Decimal? @map("cutting_rate") @db.Decimal(5, 2)
  unit            String?  @default("片") @map("unit") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at")
  
  @@map("cutting_rate_stat")
  @@index([statDate])
  @@index([nickelPlateType])
}

// 装车明细表
model LoadingDetail {
  id             Int      @id @default(autoincrement())
  loadDate       DateTime @map("load_date") @db.Date
  transportType  String?  @map("transport_type") @db.VarChar(20)
  sectionCount   Int      @default(0) @map("section_count")
  weight         Decimal  @default(0) @map("weight") @db.Decimal(10, 3)
  containerCount Int      @default(0) @map("container_count")
  truckCount     Int      @default(0) @map("truck_count")
  createdAt      DateTime @default(now()) @map("created_at")
  
  @@map("loading_detail")
  @@index([loadDate])
}

// ==================== 缺陷检测模块 ====================
model DefectType {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?  @db.Text
  category     String?
  color        String?  @default("#ff0000")
  thumbnailUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  samples     DefectSample[]
  annotations DefectAnnotation[]
}

model DefectSample {
  id           Int      @id @default(autoincrement())
  defectTypeId Int
  imageUrl     String
  thumbnailUrl String?
  sourcePath   String?  @db.Text
  description  String?  @db.Text
  status       String   @default("pending")
  reviewedBy   Int?
  reviewedAt   DateTime?
  width        Int?
  height       Int?
  fileSize     Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  defectType  DefectType @relation(fields: [defectTypeId], references: [id])
  annotations DefectAnnotation[]
}

model DefectAnnotation {
  id           Int      @id @default(autoincrement())
  sampleId     Int
  defectTypeId Int
  x            Decimal  @db.Decimal(8, 4)
  y            Decimal  @db.Decimal(8, 4)
  width        Decimal  @db.Decimal(8, 4)
  height       Decimal  @db.Decimal(8, 4)
  confidence   Decimal? @db.Decimal(5, 4)
  description  String?  @db.Text
  annotatedBy  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sample     DefectSample @relation(fields: [sampleId], references: [id])
  defectType DefectType   @relation(fields: [defectTypeId], references: [id])
}

model AiRecognitionHistory {
  id           Int      @id @default(autoincrement())
  imageUrl     String   @map("image_url") @db.VarChar(200)
  result       String   @db.Text
  itemCount    Int      @map("item_count")
  status       String   @default("success") @db.VarChar(20)
  errorMessage String?  @map("error_message") @db.VarChar(500)
  batchNo      String?  @map("batch_no") @db.VarChar(50)
  grade        String?  @db.VarChar(20)
  date         DateTime? @db.Date
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("ai_recognition_history")
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

// ==================== 平面库配货 ====================

model DistributionOrder {
  id             Int      @id @default(autoincrement())
  orderNo        String   @unique @map("order_no") @db.VarChar(50)
  customerId     Int      @map("customer_id")
  customerName   String?  @map("customer_name") @db.VarChar(100)  // 冗余字段，快速显示
  productSpec    String?  @map("product_spec") @db.VarChar(100)   // 产品规格
  targetGrade    String?  @map("target_grade") @db.VarChar(20)    // 目标品级
  totalWeight    Decimal? @map("total_weight") @db.Decimal(10, 3) // 总重量
  totalPieces    Int?     @map("total_pieces")                     // 总片数
  status         String   @default("draft") @db.VarChar(20)       // draft/confirmed/shipping/shipped/cancelled
  shippedAt      DateTime? @map("shipped_at")
  driverName     String?  @map("driver_name") @db.VarChar(50)     // 司机
  vehicleNo      String?  @map("vehicle_no") @db.VarChar(20)      // 车牌号
  remark         String?  @db.Text
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  customer       Customer                @relation(fields: [customerId], references: [id])
  items          DistributionOrderItem[]

  @@map("distribution_order")
  @@index([orderNo])
  @@index([status])
  @@index([customerId])
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  contact     String?  @db.VarChar(50)
  phone       String?  @db.VarChar(20)
  address     String?  @db.VarChar(200)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders DistributionOrder[]

  @@map("distribution_customer")
  @@index([name])
}

// 库存批次表（平面库可用库存）
model InventoryStock {
  id               Int      @id @default(autoincrement())
  batchNo          String   @map("batch_no") @db.VarChar(50)     // 批号
  grade            String   @db.VarChar(20)                       // 品级 Ni9996/Ni9990...
  specification    String?  @db.VarChar(50)                       // 规格
  weight           Decimal  @default(0) @db.Decimal(10, 3)        // 重量 kg
  pieceCount       Int      @default(0) @map("piece_count")       // 片数
  location         String?  @db.VarChar(100)                      // 存放位置
  nickelContent    Decimal? @map("nickel_content") @db.Decimal(5, 2)  // 镍含量 %
  impurityContent  String?  @map("impurity_content") @db.VarChar(100) // 杂质含量
  status           String   @default("available") @db.VarChar(20)  // available/reserved/shipped
  inspectionDate   DateTime? @map("inspection_date") @db.Date      // 检测日期
  certificateNo    String?  @map("certificate_no") @db.VarChar(50) // 质量证明书编号
  remark           String?  @db.Text
  sourceType       String?  @map("source_type") @db.VarChar(20)    // ai/manual/import
  sourceImage      String?  @map("source_image") @db.VarChar(200)  // AI识别源图片URL
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  orderItems       DistributionOrderItem[]

  @@map("inventory_stock")
  @@index([batchNo])
  @@index([grade])
  @@index([status])
}

// 配货单明细表
model DistributionOrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int      @map("order_id")
  stockId     Int      @map("stock_id")
  weight      Decimal  @default(0) @db.Decimal(10, 3)           // 配货重量
  pieceCount  Int      @default(0) @map("piece_count")           // 配货片数
  createdAt   DateTime @default(now()) @map("created_at")

  order       DistributionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stock       InventoryStock    @relation(fields: [stockId], references: [id])

  @@map("distribution_order_item")
  @@index([orderId])
  @@index([stockId])
}

// ==================== 审计日志 ====================
model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  module    String
  details   String?  @db.Text
  ip        String?
  createdAt DateTime @default(now())
}
